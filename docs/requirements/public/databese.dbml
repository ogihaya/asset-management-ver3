// Synchronized pair:
// - English DBML: docs/requirements/public/databese.dbml
// - Japanese DBML: docs/requirements/public/databese_ja.dbml
// Keep both files synchronized whenever either file is updated.
// Asset management application database design
// PostgreSQL-oriented DBML
// *_month columns store the first day of the target month.
// Complex business rules such as non-overlapping effective periods,
// duplicate names at the same effective timing, and allocation total = 100.00
// are enforced by the application layer.
// Missing monthly value rows mean "not entered yet", so 0 and blank can be distinguished.

Table users {
  id int [pk, increment]
  email varchar(255) [not null]
  password_hash varchar(255) [not null]
  name varchar(255)
  deleted_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    email [unique]
  }
}

Table user_sessions {
  id int [pk, increment]
  user_id int [not null, ref: > users.id]
  session_token_hash varchar(255) [not null]
  expires_at timestamptz [not null]
  revoked_at timestamptz
  last_seen_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    session_token_hash [unique]
    user_id
  }
}

Table password_reset_tokens {
  id int [pk, increment]
  user_id int [not null, ref: > users.id]
  token_hash varchar(255) [not null]
  expires_at timestamptz [not null]
  used_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    token_hash [unique]
    user_id
  }
}

Table asset_definitions {
  id int [pk, increment]
  user_id int [not null, ref: > users.id]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    user_id
  }
}

Table asset_name_revisions {
  id int [pk, increment]
  asset_id int [not null, ref: > asset_definitions.id]
  effective_month date [not null]
  name varchar(255) [not null]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (asset_id, effective_month) [unique]
    asset_id
  }
}

Table asset_visibility_periods {
  id int [pk, increment]
  asset_id int [not null, ref: > asset_definitions.id]
  visible_from_month date [not null]
  visible_to_month date
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (asset_id, visible_from_month) [unique]
    asset_id
  }
}

Table income_definitions {
  id int [pk, increment]
  user_id int [not null, ref: > users.id]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    user_id
  }
}

Table income_name_revisions {
  id int [pk, increment]
  income_id int [not null, ref: > income_definitions.id]
  effective_month date [not null]
  name varchar(255) [not null]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (income_id, effective_month) [unique]
    income_id
  }
}

Table income_visibility_periods {
  id int [pk, increment]
  income_id int [not null, ref: > income_definitions.id]
  visible_from_month date [not null]
  visible_to_month date
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (income_id, visible_from_month) [unique]
    income_id
  }
}

Table settings_revisions {
  id int [pk, increment]
  user_id int [not null, ref: > users.id]
  effective_month date [not null]
  emergency_fund_yen bigint [not null]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (user_id, effective_month) [unique]
    user_id
  }
}

Table investment_target_definitions {
  id int [pk, increment]
  user_id int [not null, ref: > users.id]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    user_id
  }
}

Table investment_target_name_revisions {
  id int [pk, increment]
  investment_target_id int [not null, ref: > investment_target_definitions.id]
  effective_month date [not null]
  name varchar(255) [not null]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (investment_target_id, effective_month) [unique]
    investment_target_id
  }
}

Table investment_target_visibility_periods {
  id int [pk, increment]
  investment_target_id int [not null, ref: > investment_target_definitions.id]
  visible_from_month date [not null]
  visible_to_month date
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (investment_target_id, visible_from_month) [unique]
    investment_target_id
  }
}

Table settings_revision_target_allocations {
  id int [pk, increment]
  settings_revision_id int [not null, ref: > settings_revisions.id]
  investment_target_id int [not null, ref: > investment_target_definitions.id]
  ratio_percent numeric(5,2) [not null]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (settings_revision_id, investment_target_id) [unique]
    settings_revision_id
    investment_target_id
  }
}

Table monthly_records {
  id int [pk, increment]
  user_id int [not null, ref: > users.id]
  record_month date [not null]
  confirmed boolean [not null, default: false]
  confirmed_at timestamptz
  expense_final_yen bigint
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    (user_id, record_month) [unique]
    user_id
    record_month
  }
}

Table monthly_asset_values {
  id int [pk, increment]
  monthly_record_id int [not null, ref: > monthly_records.id]
  asset_id int [not null, ref: > asset_definitions.id]
  value_yen bigint [not null]

  Indexes {
    (monthly_record_id, asset_id) [unique]
    monthly_record_id
    asset_id
  }
}

Table monthly_income_values {
  id int [pk, increment]
  monthly_record_id int [not null, ref: > monthly_records.id]
  income_id int [not null, ref: > income_definitions.id]
  value_yen bigint [not null]

  Indexes {
    (monthly_record_id, income_id) [unique]
    monthly_record_id
    income_id
  }
}

Table monthly_investment_valuations {
  id int [pk, increment]
  monthly_record_id int [not null, ref: > monthly_records.id]
  investment_target_id int [not null, ref: > investment_target_definitions.id]
  valuation_yen bigint [not null]

  Indexes {
    (monthly_record_id, investment_target_id) [unique]
    monthly_record_id
    investment_target_id
  }
}

Table life_plan_events {
  id int [pk, increment]
  user_id int [not null, ref: > users.id]
  event_month date [not null]
  title varchar(255) [not null]
  amount_yen bigint [not null]
  note text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    user_id
    event_month
  }
}
